# Nginx configuration for utkarsh-planner.duckdns.org
# Place at: /etc/nginx/sites-available/life-planner
# Enable with: sudo ln -s /etc/nginx/sites-available/life-planner /etc/nginx/sites-enabled/
# Then: sudo certbot --nginx -d utkarsh-planner.duckdns.org

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name utkarsh-planner.duckdns.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name utkarsh-planner.duckdns.org;

    # Certbot will populate these:
    # ssl_certificate     /etc/letsencrypt/live/utkarsh-planner.duckdns.org/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/utkarsh-planner.duckdns.org/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Proxy API calls to Express
    location /api/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Proxy auth routes to Express
    location /auth/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Health check
    location /health {
        proxy_pass http://127.0.0.1:3001;
    }

    # SPA — serve Vite dist, fallback to index.html for client-side routing
    location / {
        root /var/www/life-planner;
        try_files $uri $uri/ /index.html;
        expires 1h;
        add_header Cache-Control "public, no-transform";
    }
}
